# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers (at least one required for OCR & insights)
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Rate Limiting (optional — skipped if not set)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# App
NEXT_PUBLIC_APP_URL=https://expensevision.tech

# Push Notifications (optional — subscription UI only, server-side send not yet implemented)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Playwright E2E (optional — tests skip cleanly if not set)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

# Render Deployment
# Health check path: /api/warmup
# Set NEXT_PUBLIC_APP_URL to your Render service URL (e.g. https://your-app.onrender.com)
