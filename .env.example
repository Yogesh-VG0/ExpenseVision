NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local development default. In production set this to your public HTTPS origin,
# for example: https://expensevision.tech
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Receipt OCR — optional Veryfi (primary when all three are set)
VERYFI_CLIENT_ID=
VERYFI_API_KEY=
VERYFI_USERNAME=

# AI / OCR — configure Gemini and/or OpenRouter for OCR fallbacks and insights.
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional: Upstash Redis for rate limiting.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: Web Push (budget alerts + weekly summary delivery).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cron: Render weekly job calls POST /api/cron/weekly-summary with Authorization: Bearer …
CRON_SECRET=