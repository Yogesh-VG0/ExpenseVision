# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Receipt OCR — configure Veryfi and/or Gemini and/or OpenRouter (see README)
VERYFI_CLIENT_ID=
VERYFI_API_KEY=
VERYFI_USERNAME=

# AI / OCR fallbacks & insights
GEMINI_API_KEY=your-gemini-api-key
OPENROUTER_API_KEY=your-openrouter-api-key

# Rate Limiting (optional — skipped if not set)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Push Notifications (optional — enables push delivery for budget alerts + weekly summaries)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cron Secret (required for scheduled weekly summary endpoint)
# Generate any random string, e.g.: openssl rand -hex 32
CRON_SECRET=

# Playwright E2E (optional — tests skip cleanly if not set)
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=
